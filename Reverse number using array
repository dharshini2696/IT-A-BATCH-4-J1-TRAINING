import java.util.Scanner;
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        int[] a = new int[10];
        int count = 0;
        while (n > 0) {
            a[count] = n % 10;
            n = n / 10;
            count++;
        }
        for (int i = 0; i < count; i++) {
            System.out.print(a[i]);
        }
    }
}
